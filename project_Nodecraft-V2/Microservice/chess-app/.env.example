APP_NAME=ChessApp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DATABASE=chess_app
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate: php -r "echo base64_encode(random_bytes(64));"
JWT_SECRET=
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# ─── Internal API Key (komunikasi antar module) ───────────────────────────────
# Generate: php -r "echo bin2hex(random_bytes(32));"
INTERNAL_API_KEY=

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_LOGIN=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Backup ───────────────────────────────────────────────────────────────────
BACKUP_PATH=/var/backups/chess_app
BACKUP_RETENTION_DAYS=7

# ─── Node.js (untuk ChessValidator) ──────────────────────────────────────────
NODE_BINARY=node

# ─── Queue & Cache ────────────────────────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
