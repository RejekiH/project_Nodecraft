APP_NAME="NodeChess User Service"
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://localhost:8001

# Port service ini
SERVICE_PORT=8001
SERVICE_NAME=user-service

# MongoDB - Primary
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=nodechess_users
MONGODB_USERNAME=
MONGODB_PASSWORD=

# MongoDB - Replica (untuk Fase 3)
MONGODB_REPLICA_URI=mongodb://localhost:27018
MONGODB_REPLICA_DATABASE=nodechess_users

# JWT Configuration
JWT_SECRET=GANTI_DENGAN_SECRET_PANJANG_DAN_ACAK_MINIMAL_64_KARAKTER
JWT_EXPIRES_IN=3600          # 1 jam (detik)
JWT_REFRESH_EXPIRES_IN=604800 # 7 hari (detik)

# Inter-service Communication (Fase 4)
GAMEPLAY_SERVICE_URL=http://localhost:8002
ROOM_SERVICE_URL=http://localhost:8003
BACKUP_SERVICE_URL=http://localhost:8004
INTERNAL_API_KEY=GANTI_DENGAN_KEY_RAHASIA_UNTUK_KOMUNIKASI_ANTAR_SERVICE

# Rate Limiting
RATE_LIMIT_REGISTER=10   # per menit per IP
RATE_LIMIT_LOGIN=20      # per menit per IP
RATE_LIMIT_API=100       # per menit per token

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# RabbitMQ (Fase 4)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
