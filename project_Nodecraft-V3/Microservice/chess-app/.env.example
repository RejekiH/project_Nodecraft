APP_NAME=ChessApp
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DATABASE=chess_app
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: php -r "echo base64_encode(random_bytes(64));"
JWT_SECRET=
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# ─── Internal API Key ─────────────────────────────────────────────────────────
# Generate: php -r "echo bin2hex(random_bytes(32));"
# Harus sama antara Laravel dan WebSocket server
INTERNAL_API_KEY=

# ─── WebSocket Server (websocket-server.js) ───────────────────────────────────
# Port yang dijalankan websocket-server.js
WS_PORT=6001
# URL Laravel untuk dipanggil WebSocket server
LARAVEL_URL=http://localhost:8000
# Origin yang diizinkan terhubung ke WebSocket (frontend URL)
# Gunakan * untuk development, spesifikkan untuk production
CORS_ORIGIN=*

# ─── Chess Validator (Node.js) ────────────────────────────────────────────────
NODE_BINARY=node
# Path relatif dari root project Laravel
CHESS_VALIDATOR_SCRIPT=
CHESS_VALIDATOR_TIMEOUT=5

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_LOGIN=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Backup ───────────────────────────────────────────────────────────────────
BACKUP_PATH=/var/backups/chess_app
BACKUP_RETENTION_DAYS=7
HEARTBEAT_STALE_MINUTES=3
HEARTBEAT_OFFLINE_THRESHOLD=5

# ─── Queue & Cache ────────────────────────────────────────────────────────────
QUEUE_CONNECTION=sync
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
